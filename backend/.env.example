# =============================================================================
# Azure AI Red Team Demo - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values
# DO NOT commit .env files with real secrets to version control
# =============================================================================

# -----------------------------------------------------------------------------
# Application Mode
# -----------------------------------------------------------------------------
# Set to 'demo' for mock responses (no Azure connection needed)
# Set to 'azure' to connect to real Azure AI Foundry/OpenAI endpoints
RUN_MODE=azure

# -----------------------------------------------------------------------------
# Azure AI Foundry Resource (existing resource)
# -----------------------------------------------------------------------------
# The existing Foundry resource name - used to construct endpoint if
# AZURE_OPENAI_ENDPOINT is not explicitly set
FOUNDRY_RESOURCE_NAME=mkhalib-4370-resource

# Optional: AI project name within the Foundry resource
# AZURE_AI_PROJECT_NAME=my-redteam-project

# -----------------------------------------------------------------------------
# Azure OpenAI Configuration
# -----------------------------------------------------------------------------
# Full endpoint URL (overrides constructed URL from FOUNDRY_RESOURCE_NAME)
# Example: https://mkhalib-4370-resource.openai.azure.com
AZURE_OPENAI_ENDPOINT=https://mkhalib-4370-resource.openai.azure.com

# Model deployment name (required for Azure mode)
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o

# API version (optional, has sensible default)
AZURE_OPENAI_API_VERSION=2024-02-15-preview

# -----------------------------------------------------------------------------
# Authentication - Option 1: API Key (simpler, less secure)
# -----------------------------------------------------------------------------
# Use API key authentication - provide your Azure OpenAI key
# AZURE_OPENAI_API_KEY=your-api-key-here

# -----------------------------------------------------------------------------
# Authentication - Option 2: Entra ID / Service Principal (recommended)
# -----------------------------------------------------------------------------
# For production, use Entra ID authentication with a service principal
# Requires: Azure tenant ID, client ID, and client secret
# AZURE_TENANT_ID=your-tenant-id
# AZURE_CLIENT_ID=your-client-id
# AZURE_CLIENT_SECRET=your-client-secret

# -----------------------------------------------------------------------------
# Authentication - Option 3: Default Azure Credential
# -----------------------------------------------------------------------------
# If no API key or service principal is configured, the app will attempt
# to use DefaultAzureCredential which works with:
# - Azure CLI login (az login)
# - Managed Identity (when running in Azure)
# - Visual Studio Code Azure extension
# No additional configuration needed for this option

# -----------------------------------------------------------------------------
# Comparison Mode (baseline vs guarded targets)
# -----------------------------------------------------------------------------
# For A/B comparison testing, you can configure two different deployments
# Leave empty to use AZURE_OPENAI_DEPLOYMENT_NAME for both targets
# BASELINE_DEPLOYMENT_NAME=gpt-4o-baseline
# GUARDED_DEPLOYMENT_NAME=gpt-4o-guarded

# -----------------------------------------------------------------------------
# Azure AI Content Safety - Prompt Shields
# -----------------------------------------------------------------------------
# Configure Azure AI Content Safety for jailbreak and prompt injection detection
# Uses the existing mkhalib-4370-resource Foundry environment context
#
# To enable:
# 1. Create a Content Safety resource in Azure (or use existing one)
# 2. Set the endpoint and key below
#
# If not configured, the app will use a mock safety provider for demos
AZURE_CONTENT_SAFETY_ENDPOINT=https://mkhalib-4370-resource.cognitiveservices.azure.com/
# AZURE_CONTENT_SAFETY_KEY=your-content-safety-key
AZURE_CONTENT_SAFETY_API_VERSION=2024-02-15-preview

# -----------------------------------------------------------------------------
# Safety Layer Configuration
# -----------------------------------------------------------------------------
# Enable safety layer checks before calling target model
SAFETY_LAYER_ENABLED=true

# Fall back to mock safety provider if Azure Content Safety is unavailable
# Set to false to skip safety checks entirely when Azure is not configured
SAFETY_LAYER_FALLBACK_TO_MOCK=true

# -----------------------------------------------------------------------------
# Telemetry Configuration
# -----------------------------------------------------------------------------
# Enable structured telemetry logging for all attack and campaign runs
TELEMETRY_ENABLED=true

# Output telemetry as structured JSON (otherwise human-readable format)
# Set to true for machine parsing, false for demo narration
TELEMETRY_CONSOLE_STRUCTURED_JSON=false

# -----------------------------------------------------------------------------
# Azure Application Insights (Optional)
# -----------------------------------------------------------------------------
# For production monitoring, provide the connection string
# When configured, telemetry will be sent to both console and App Insights
#
# To get your connection string:
# 1. Go to Azure Portal > Application Insights resource
# 2. Copy the Connection String from the Overview page
#
# APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=xxx;IngestionEndpoint=https://xxx.in.applicationinsights.azure.com/

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------
HOST=0.0.0.0
PORT=8000
DEBUG=true

# =============================================================================
# Quick Start Guide
# =============================================================================
# 1. Copy this file: cp .env.example .env
# 2. For demo mode (no Azure): Keep RUN_MODE=demo
# 3. For Azure mode:
#    a. Set RUN_MODE=azure
#    b. The FOUNDRY_RESOURCE_NAME is already set to mkhalib-4370-resource
#    c. Set AZURE_OPENAI_DEPLOYMENT_NAME to your model deployment
#    d. Choose ONE authentication method:
#       - API Key: Set AZURE_OPENAI_API_KEY
#       - Service Principal: Set AZURE_TENANT_ID, AZURE_CLIENT_ID, AZURE_CLIENT_SECRET
#       - Azure CLI: Just run 'az login' before starting the app
# 4. For safety layer (Prompt Shields):
#    a. Set AZURE_CONTENT_SAFETY_ENDPOINT and AZURE_CONTENT_SAFETY_KEY
#    b. Or keep SAFETY_LAYER_FALLBACK_TO_MOCK=true to use mock provider
# =============================================================================
